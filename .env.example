# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# AirLabs API key — https://airlabs.co/
AIRLABS_API_KEY=your_airlabs_api_key_here

# CheckWX METAR weather API key — https://www.checkwx.com/
CHECKWX_API_KEY=your_checkwx_api_key_here

# Mapbox public token (starts with pk.) — https://account.mapbox.com/
MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Cesium Ion access token (optional — required only for the Cesium 3-D map) — https://ion.cesium.com/
CESIUM_TOKEN=your_cesium_ion_token_here

# OpenSky Network credentials (optional — only needed for ML model training)
# Register at https://opensky-network.org/
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password

# ── Email alerts (optional) ────────────────────────────────────────────────────
# When the AirLabs API quota is exhausted or the key becomes invalid,
# the app will send you an email so you can act immediately.
#
# Gmail setup:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to: Google Account → Security → App passwords
#   3. Generate an App Password (16 chars) and paste it below
#   4. Use your normal @gmail.com address for ALERT_EMAIL_FROM
#
ALERT_EMAIL_FROM=your.email@gmail.com
ALERT_EMAIL_TO=your.email@gmail.com        # defaults to FROM if omitted
ALERT_EMAIL_PASSWORD=your_gmail_app_password_here
# ALERT_SMTP_HOST=smtp.gmail.com           # default — change for Outlook/Yahoo etc.
# ALERT_SMTP_PORT=587                      # default STARTTLS port
